<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<nav
  id="smart-header"
  class="bg-white shadow-md fixed top-0 left-0 w-full z-50 transition-transform duration-300 ease-in-out translate-y-0"
  x-data="{ mobileMenuOpen: false, servicesOpen: false, mobileServicesOpen: false }"
>
  <div class="max-w-full pl-4 lg:pl-8 pr-4 lg:pr-0 py-2">
    <div class="flex justify-between items-center h-12 md:h-16 relative w-full">

      <div class="flex-shrink-0 flex items-center z-20">
        <a href="/" class="flex items-center gap-3 md:gap-4">
          <img class="h-12 md:h-14 w-auto" src="/assets/logos/frog_best.svg" alt="Wisefrog Icon">
          <img class="h-10 md:h-10 w-auto" src="/assets/logos/wisefrog_text.svg" alt="Wisefrog Name">
        </a>
      </div>

      <div class="hidden md:flex absolute left-1/2 items-center z-10 -translate-x-1/2">
        <div class="flex items-center space-x-6 lg:space-x-8">
          <a href="/" class="text-black hover:text-blue-900 px-3 py-2 text-lg lg:text-xl font-bold whitespace-nowrap">Home</a>

          <div
            class="relative pb-2"
            @mouseenter="clearTimeout(window.__wfServicesCloseTimer); servicesOpen = true"
            @mouseleave="window.__wfServicesCloseTimer = setTimeout(() => { servicesOpen = false }, 250)"
            @keydown.escape.window="servicesOpen = false"
          >
            <button
              type="button"
              class="text-black hover:text-blue-900 px-3 py-2 text-lg lg:text-xl font-bold whitespace-nowrap flex items-center gap-2 transition-colors duration-200"
              @click="servicesOpen = !servicesOpen"
              :aria-expanded="servicesOpen.toString()"
              aria-haspopup="true"
            >
              <span>Services</span>
              <svg
                class="h-4 w-4 transition-transform duration-200"
                :class="{ 'rotate-180': servicesOpen }"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div
              x-show="servicesOpen"
              x-transition:enter="transition ease-out duration-150"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-100"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
              @click.outside="servicesOpen = false"
              class="absolute left-0 top-full w-[34rem] bg-white border border-black shadow-xl px-6 py-5"
              style="display: none;"
            >
              <div class="flex flex-col gap-6 mt-2">
                {% for group in navigation.services_dropdown %}
                  <p class="px-0 text-[24px] font-bold uppercase tracking-[0.08em] text-black {% if not loop.first %}pt-6 border-t border-gray-100{% endif %}">
                    {{ group.heading }}
                  </p>

                  {% for item in group.items %}
                    <a
                      href="{{ item.url }}"
                      class="block px-0 py-2 text-[33px] font-medium leading-[1.8] text-black hover:bg-gray-50 hover:text-black transition-colors duration-150"
                    >
                      {{ item.label }}
                    </a>
                  {% endfor %}
                {% endfor %}
              </div>
            </div>
          </div>

          <a href="/portfolio/" class="text-black hover:text-blue-900 px-3 py-2 text-lg lg:text-xl font-bold whitespace-nowrap">Portfolio</a>
          <a href="/team/" class="text-black hover:text-blue-900 px-3 py-2 text-lg lg:text-xl font-bold whitespace-nowrap">About Us</a>
          <a href="/contact/" class="text-black hover:text-blue-900 px-3 py-2 text-lg lg:text-xl font-bold whitespace-nowrap">Contact</a>
        </div>
      </div>

      <div class="flex items-center md:hidden z-20">
        <button
          @click="mobileMenuOpen = !mobileMenuOpen"
          type="button"
          class="text-gray-500 hover:text-blue-900 focus:outline-none"
          :aria-expanded="mobileMenuOpen.toString()"
          aria-label="Toggle menu"
        >
          <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path x-show="!mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path x-show="mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" style="display: none;" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div x-show="mobileMenuOpen" class="md:hidden bg-white border-t border-gray-200" style="display: none;">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href="/" class="block text-black hover:bg-gray-50 px-3 py-2 rounded-md text-2xl font-bold">Home</a>

      <div class="overflow-hidden">
        <button
          @click="mobileServicesOpen = !mobileServicesOpen"
          type="button"
          class="w-full flex items-center justify-between text-left text-black hover:bg-gray-50 px-3 py-3 text-2xl font-bold transition-colors duration-150"
          :aria-expanded="mobileServicesOpen.toString()"
        >
          <span>Services</span>
        </button>

        <div x-show="mobileServicesOpen" x-transition class="bg-gray-50 px-6 pb-5 pt-3" style="display: none;">
          {% for group in navigation.services_dropdown %}
            <div class="{% if not loop.first %}mt-4 pt-4 border-t border-gray-200{% else %}mt-2{% endif %}">
              <div class="flex flex-col gap-6">
                <p class="px-0 pb-0 text-[1.5rem] font-bold uppercase tracking-[0.08em] text-black">
                  {{ group.heading }}
                </p>

                {% for item in group.items %}
                  <a
                    href="{{ item.url }}"
                    class="block px-0 py-2 text-[2.25rem] font-medium leading-[1.8] text-black hover:bg-white hover:text-black transition-colors duration-150"
                  >
                    {{ item.label }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <a href="/portfolio/" class="block text-black hover:bg-gray-50 px-3 py-2 rounded-md text-2xl font-bold">Portfolio</a>
      <a href="/team/" class="block text-black hover:bg-gray-50 px-3 py-2 rounded-md text-2xl font-bold">About Us</a>
      <a href="/contact/" class="block text-black hover:bg-gray-50 px-3 py-2 rounded-md text-2xl font-bold">Contact</a>
    </div>
  </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('smart-header');
    if (!header) return;

    let lastScrollY = window.scrollY;
    let ticking = false;

    const getThreshold = () => {
        const heroSection = document.querySelector('main > section:first-of-type');
        return heroSection ? heroSection.offsetHeight : 300;
    };

    const updateHeader = () => {
        const currentScrollY = window.scrollY;
        const threshold = getThreshold();

        if (currentScrollY < threshold) {
            header.classList.remove('-translate-y-full');
            header.classList.add('translate-y-0');
        }
        else if (currentScrollY > lastScrollY) {
            header.classList.remove('translate-y-0');
            header.classList.add('-translate-y-full');
        }
        else {
            header.classList.remove('-translate-y-full');
            header.classList.add('translate-y-0');
        }

        lastScrollY = currentScrollY;
        ticking = false;
    };

    window.addEventListener('scroll', () => {
        if (!ticking) {
            window.requestAnimationFrame(updateHeader);
            ticking = true;
        }
    }, { passive: true });
});
</script>
