---
layout: layouts/base.njk
---
<div class="max-w-5xl mx-auto px-6 py-12 lg:py-16">
  <article class="space-y-12">
    <header class="space-y-6">
      <h1 class="text-4xl lg:text-5xl font-bold text-black leading-tight">
        {{ title }}
      </h1>

      {% if summary %}
        <p class="text-lg lg:text-xl text-black leading-relaxed max-w-3xl">
          {{ summary }}
        </p>
      {% endif %}

      {% if hero_image %}
        <figure class="overflow-hidden rounded-2xl shadow-lg bg-gray-100">
          <img
            src="{{ hero_image }}"
            alt="{{ title }}"
            class="w-full h-auto object-cover"
          >
        </figure>
      {% endif %}
    </header>

    {% if blocks and blocks.length %}
      <div class="space-y-12">
        {% for block in blocks %}
          {% if block.type == "text" %}
            <section class="space-y-4">
              {% if block.heading %}
                <h2 class="text-2xl lg:text-3xl font-bold text-black">
                  {{ block.heading }}
                </h2>
              {% endif %}
              <div class="prose prose-lg max-w-none text-black">
                {{ block.body | safe }}
              </div>
            </section>
          {% elif block.type == "image" %}
            <figure class="space-y-4">
              <div class="overflow-hidden rounded-2xl shadow-md bg-gray-100">
                <img
                  src="{{ block.image }}"
                  alt="{{ block.alt }}"
                  class="w-full h-auto object-cover"
                >
              </div>
              {% if block.caption %}
                <figcaption class="text-sm text-black">
                  {{ block.caption }}
                </figcaption>
              {% endif %}
            </figure>
          {% elif block.type == "embed" %}
            <section class="space-y-4">
              {% if block.title %}
                <h2 class="text-2xl lg:text-3xl font-bold text-black">
                  {{ block.title }}
                </h2>
              {% endif %}

              {% if block.embed_type == "iframe" and block.embed_url %}
                <div class="aspect-video overflow-hidden rounded-2xl shadow-md bg-gray-100">
                  <iframe
                    src="{{ block.embed_url }}"
                    title="{{ block.title or title }}"
                    class="w-full h-full border-0"
                    loading="lazy"
                  ></iframe>
                </div>
              {% elif block.embed_type == "include" and block.include_key %}
                <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 p-6 text-black">
                  Internal embed placeholder: {{ block.include_key }}
                </div>
              {% endif %}

              {% if block.caption %}
                <p class="text-sm text-black">
                  {{ block.caption }}
                </p>
              {% endif %}
            </section>
          {% elif block.type == "image_swipe" %}
            <section class="space-y-4 w-full">
              <img-comparison-slider class="w-full rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.35)] overflow-hidden outline-none" style="--divider-width: 3px; --divider-color: rgba(255, 255, 255, 0.95);" value="50" hover="false" tabindex="0">
                <img slot="first" src="{{ block.image_1 }}" alt="{{ block.alt_1 }}" class="block w-full h-auto object-contain bg-gray-100">
                <img slot="second" src="{{ block.image_2 }}" alt="{{ block.alt_2 }}" class="block w-full h-auto object-contain bg-gray-100">
                
                <div slot="handle" class="w-[60px] h-[60px] sm:w-[72px] sm:h-[72px] flex items-center justify-center rounded-full bg-black/72 border-[3px] border-white backdrop-blur-[4px] pointer-events-none transition-all duration-200 ease-out shadow-[0_0_0_6px_rgba(255,255,255,0.18),0_8px_24px_rgba(0,0,0,0.45)] group-hover:scale-108 group-hover:bg-black/90 group-hover:shadow-[0_0_0_8px_rgba(255,255,255,0.22),0_10px_28px_rgba(0,0,0,0.55)] group-focus-within:scale-108 group-focus-within:bg-black/90 group-focus-within:shadow-[0_0_0_8px_rgba(255,255,255,0.22),0_10px_28px_rgba(0,0,0,0.55)]" aria-hidden="true">
                  <span class="text-white text-base sm:text-[1.15rem] font-bold tracking-[0.12em] leading-none">◀ ▶</span>
                </div>
              </img-comparison-slider>
            </section>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </article>
</div>
