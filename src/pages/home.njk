---
permalink: /
---

{% extends "layouts/base.njk" %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1>{{ hero_heading or title }}</h1>
    {% if hero_intro %}
      <p>{{ hero_intro }}</p>
    {% endif %}
  </div>
</section>

{% if slides and slides.length %}
<section class="carousel">
  <div class="container">
    <div class="carousel-track">
      {% for slide in slides %}
        <article class="carousel-slide">
          <h2>{{ slide.title }}</h2>
          {% if slide.body %}
            <p>{{ slide.body }}</p>
          {% endif %}
          {% if slide.cta_label and slide.cta_url %}
            <p><a href="{{ slide.cta_url }}">{{ slide.cta_label }}</a></p>
          {% endif %}
        </article>
      {% endfor %}

      {% for slide in slides %}
        <article class="carousel-slide" aria-hidden="true">
          <h2>{{ slide.title }}</h2>
          {% if slide.body %}
            <p>{{ slide.body }}</p>
          {% endif %}
          {% if slide.cta_label and slide.cta_url %}
            <p><a href="{{ slide.cta_url }}">{{ slide.cta_label }}</a></p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
{% endblock %}
